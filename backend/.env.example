# ── CarAI IDE Environment Config ──────────────────────────────
# Copy this to .env and fill in your keys. Unconfigured providers
# will show as "Not configured" in the IDE but won't crash anything.

PORT=3001
WORKSPACE_ROOT=/workspace

# ── AI Provider Keys ───────────────────────────────────────────
# Anthropic (Claude)
ANTHROPIC_API_KEY=

# OpenRouter (free models available even without paid key)
OPENROUTER_API_KEY=

# DeepSeek
DEEPSEEK_API_KEY=

# Google Gemini
GEMINI_API_KEY=

# Hugging Face
HF_API_KEY=

# Ollama (your self-hosted instance)
OLLAMA_BASE_URL=https://ollama.carai.agency
OLLAMA_API_KEY=   # leave blank if no auth required
